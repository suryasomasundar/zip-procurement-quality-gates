{
  "name": "zip-procurement-quality-gates",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -s first \"npm --workspace @zip-takehome/api run dev\" \"npm --workspace @zip-takehome/web run dev\"",
    "dev:e2e": "concurrently -k -s first \"npm --workspace @zip-takehome/api run start\" \"npm --workspace @zip-takehome/web run dev -- --host 0.0.0.0 --port 4173\"",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "npm --workspace @zip-takehome/web run test:e2e",
    "test": "npm run test:unit && npm run test:integration",
    "security:audit": "npm audit --audit-level=moderate",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run coverage && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "supertest": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.2",
    "vitest": "^3.1.2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=20.11.1"
  }
}
